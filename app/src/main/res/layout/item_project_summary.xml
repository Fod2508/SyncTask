<?xml version="1.0" encoding="utf-8"?>
<!-- Item Master: Đề Tài (Project) — Material Design 3 -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProjectSummary"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FCFCFC"
    app:strokeWidth="0dp"
    app:rippleColor="#1A6C63FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Icon thư mục -->
        <TextView
            android:id="@+id/tvProjectIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="📂"
            android:textSize="24sp"
            android:gravity="center"
            android:background="@android:color/transparent" />

        <!-- Nội dung: Tên đề tài + Số lượng -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên Đề Tài"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTaskCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đầu việc"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Nút xóa dự án -->
        <ImageButton
            android:id="@+id/btnDeleteProject"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Xóa toàn bộ dự án"
            android:scaleType="centerInside"
            android:tint="#BDBDBD"
            android:layout_marginEnd="8dp" />

        <!-- Mũi tên chi tiết -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="14sp"
            android:textColor="#BDBDBD" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
