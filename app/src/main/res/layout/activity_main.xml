<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Minimalism Header + Fixed TabLayout + ViewPager2
    ─────────────────────────────────────────────────────────────────────
    Cấu trúc (từ trên xuống dưới):
      1. Root: LinearLayout vertical — đảm bảo các thành phần KHÔNG chồng lấn
      2. Header tùy chỉnh (LinearLayout horizontal) — thay thế AppBarLayout/Toolbar
      3. Divider mỏng — phân tách header và tab một cách tinh tế
      4. TabLayout — màu sắc hard-coded, không phụ thuộc color attribute động
      5. ViewPager2 — layout_weight="1" để lấp đầy không gian còn lại
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 1. CUSTOM HEADER — Minimalism Style (thay thế Toolbar/AppBar) -->
    <!--    • Nền trắng, không có shadow nặng                          -->
    <!--    • Logo Icon + Title căn trái, padding thoáng               -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="#FFFFFF">

        <!-- App Logo -->
        <ImageView
            android:id="@+id/ivAppLogo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="SyncTask Logo"
            android:scaleType="fitCenter" />

        <!-- App Title: "SyncTask" — phong chữ đậm, hiện đại -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SyncTask"
            android:textSize="32sp"
            android:textColor="#6200EE"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.01"
            android:layout_marginStart="12dp"
            android:includeFontPadding="false" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 2. DIVIDER — Đường kẻ mỏng phân tách Header và TabLayout      -->
    <!--    Minimalism: không dùng elevation/shadow, chỉ 1px line      -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 3. TABLAYOUT — Fix lỗi tab tàng hình / chồng lấn              -->
    <!--    • tabTextColor="#757575"     → màu xám cho tab chưa chọn   -->
    <!--    • tabSelectedTextColor="#6200EE" → tím cho tab đang chọn   -->
    <!--    • tabIndicatorColor="#6200EE"    → gạch chân tím           -->
    <!--    • Tất cả màu hard-coded để KHÔNG bị trùng màu nền trắng    -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:contentDescription="Tab điều hướng"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#6200EE"
        app:tabIndicatorColor="#6200EE"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="#1A6200EE"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Button" />

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 4. VIEWPAGER2 — Nội dung của từng Tab                         -->
    <!--    • layout_height="0dp" + layout_weight="1"                  -->
    <!--      → Tự động lấp đầy toàn bộ không gian còn lại bên dưới   -->
    <!--    • KHÔNG đặt fixed height — sẽ bị cắt hoặc thừa khoảng     -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>